# ─── LLM Provider API Keys ──────────────────────────────────────────────────
# At least ONE provider key is required (matching your MODEL_* settings).
# Both can be set to enable mixed-provider configurations.

# Anthropic API key for Claude models
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key (required if using gemini-* models)
GEMINI_API_KEY=AIza...

# Required: OpenAI API key for embeddings
OPENAI_API_KEY=sk-...

# Required: GitHub token for PR access
GITHUB_TOKEN=ghp_...

# Repository configuration
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ─── Model Configuration ───────────────────────────────────────────────────
# Provider is auto-detected from the model name prefix:
#   "claude-*" → uses ANTHROPIC_API_KEY
#   "gemini-*" → uses GEMINI_API_KEY
#
# You can mix providers — e.g., use Gemini for cheap passes and Claude for
# verification. Only the API keys for providers you actually use are required.

# === Option A: All Claude (default) ===
MODEL_ORCHESTRATOR=claude-sonnet-4-20250514
MODEL_REVIEW_AGENT=claude-sonnet-4-20250514
MODEL_VERIFICATION=claude-sonnet-4-20250514
MODEL_SIMPLE_REVIEW=claude-haiku-4-5-20251001

# === Option B: All Gemini ===
# MODEL_ORCHESTRATOR=gemini-2.5-pro
# MODEL_REVIEW_AGENT=gemini-2.5-pro
# MODEL_VERIFICATION=gemini-2.5-pro
# MODEL_SIMPLE_REVIEW=gemini-2.5-flash

# === Option C: Mixed (Gemini agents + Claude verification) ===
# MODEL_REVIEW_AGENT=gemini-2.5-pro
# MODEL_VERIFICATION=claude-sonnet-4-20250514
# MODEL_SIMPLE_REVIEW=gemini-2.5-flash

# Optional: Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Cost controls
MAX_TOKENS_PER_REVIEW=200000
MAX_REVIEW_TIME_MS=300000
MAX_FINDINGS_BEFORE_ESCALATION=25

# Optional: Vector store path
VECTOR_STORE_PATH=./.vector-store
